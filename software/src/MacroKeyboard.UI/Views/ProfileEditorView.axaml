<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MacroKeyboard.UI.ViewModels"
             xmlns:views="using:MacroKeyboard.UI.Views"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
             x:Class="MacroKeyboard.UI.Views.ProfileEditorView"
             x:DataType="vm:ProfileEditorViewModel"
             x:Name="ProfileEditorRoot">

    <Grid RowDefinitions="Auto,*,Auto" Margin="10">

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 0 — TOPBAR
        ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#0D1117" CornerRadius="8"
                BorderBrush="#00FFFF" BorderThickness="1"
                Padding="10,6" Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                <!-- Profile label -->
                <TextBlock Grid.Column="0"
                           Text="Profile:"
                           VerticalAlignment="Center"
                           Foreground="#00FFFF" FontWeight="Bold"
                           Margin="0,0,8,0" />

                <!-- Profile ComboBox -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          MinWidth="180"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Profile name inline edit -->
                <TextBox Grid.Column="2"
                         Text="{Binding SelectedProfile.Name}"
                         PlaceholderText="Profile name…"
                         MinWidth="140"
                         VerticalAlignment="Center"
                         Margin="6,0"
                         IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <Button Grid.Column="3" Content="+ New"
                        Command="{Binding CreateNewProfileCommand}"
                        Margin="4,0" VerticalAlignment="Center" />

                <Button Grid.Column="4" Content="Export"
                        Command="{Binding ExportProfileCommand}"
                        Margin="4,0" VerticalAlignment="Center" />

                <Button Grid.Column="5" Content="Load"
                        Command="{Binding LoadProfileCommand}"
                        Margin="4,0" VerticalAlignment="Center" />

                <Button Grid.Column="6" Content="Delete"
                        Command="{Binding DeleteProfileCommand}"
                        Margin="4,0" VerticalAlignment="Center" />

                <Separator Grid.Column="7" Width="1" Height="24"
                           Background="#444" Margin="8,0" />

                <!-- Send to Device — accent button -->
                <Button Grid.Column="8"
                        Content="→ Send to Device"
                        Command="{Binding SendToDeviceCommand}"
                        Background="#0D4429" BorderBrush="#00FF00"
                        Margin="4,0" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 1 — MAIN AREA  (Canvas left · Config panel right)
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="*,310">

            <!-- ── LEFT: Canvas + breadcrumb + encoder ── -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto" Margin="0,0,8,0">

                <!-- Breadcrumb (hidden at root) -->
                <Border Grid.Row="0"
                        Background="#0D1117" CornerRadius="6" Padding="8,4" Margin="0,0,0,6"
                        IsVisible="{Binding DeviceCanvas.CanNavigateUp}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="← Back"
                                Command="{Binding NavigateUpCommand}"
                                Padding="8,3" />
                        <ItemsControl ItemsSource="{Binding DeviceCanvas.BreadcrumbPath}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text=" › " Opacity="0.4" FontSize="14" />
                                        <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Device Canvas -->
                <Border Grid.Row="1"
                        Background="#0D1117" CornerRadius="8"
                        BorderBrush="#00FFFF" BorderThickness="1"
                        Padding="12">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="⌨ BUTTONS"
                                       FontSize="13" FontWeight="Bold" Foreground="#00FFFF"
                                       Margin="0,0,0,8" />
                            <views:DeviceCanvasView DataContext="{Binding DeviceCanvas}" />

                            <TextBlock Text="Double-click a folder button to open it"
                                       FontSize="10" Opacity="0.4" Margin="4,8,0,0"
                                       IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}"
                                         Margin="0,8,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Encoder strip -->
                <Border Grid.Row="2"
                        Background="#0D1117" CornerRadius="8"
                        BorderBrush="#FFA500" BorderThickness="1"
                        Padding="10" Margin="0,8,0,0"
                        IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="🔄 ENCODER"
                                   FontSize="12" FontWeight="Bold" Foreground="#FFA500"
                                   Margin="0,0,0,4" />
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="5" ColumnSpacing="10">

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="↻ Clockwise:"
                                       FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                            <Button Grid.Row="0" Grid.Column="1"
                                    Content="{Binding EncoderCwActionDisplay}"
                                    Command="{Binding ConfigureEncoderCwCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="↺ Counter-CW:"
                                       FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                            <Button Grid.Row="1" Grid.Column="1"
                                    Content="{Binding EncoderCcwActionDisplay}"
                                    Command="{Binding ConfigureEncoderCcwCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="⏎ Press:"
                                       FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                            <Button Grid.Row="2" Grid.Column="1"
                                    Content="{Binding EncoderPressActionDisplay}"
                                    Command="{Binding ConfigureEncoderPressCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="⏎⏎ Long Press:"
                                       FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                            <Button Grid.Row="3" Grid.Column="1"
                                    Content="{Binding EncoderLongPressActionDisplay}"
                                    Command="{Binding ConfigureEncoderLongPressCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── RIGHT: Config Panel ── -->
            <Border Grid.Column="1"
                    Background="#0D1117" CornerRadius="8"
                    BorderBrush="#00FFFF" BorderThickness="1">
                <Grid RowDefinitions="*,Auto">

                    <!-- Empty state -->
                    <StackPanel Grid.Row="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding ButtonConfigViewModel, Converter={x:Static ObjectConverters.IsNull}}">
                        <TextBlock Text="🖱" FontSize="32" HorizontalAlignment="Center" Opacity="0.3" />
                        <TextBlock Text="Click a button to configure"
                                   FontSize="12" Opacity="0.4" Margin="0,8,0,0"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Config content -->
                    <ScrollViewer Grid.Row="0"
                                  IsVisible="{Binding ButtonConfigViewModel, Converter={x:Static ObjectConverters.IsNotNull}}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="0" Margin="12,10,12,0">

                            <!-- Header -->
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                                <TextBlock Text="{Binding SelectedButtonHeader}"
                                           FontSize="14" FontWeight="Bold" Foreground="#00FFFF"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="1" Content="✕" Width="26" Height="26"
                                        Command="{Binding CloseButtonConfigCommand}"
                                        Padding="0" />
                            </Grid>

                            <Separator Margin="0,0,0,8" />

                            <!-- ══ SHORT PRESS section ══ -->
                            <TextBlock Text="SHORT PRESS"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#FFA500" Opacity="0.8"
                                       Margin="0,0,0,6" />

                            <StackPanel DataContext="{Binding ButtonConfigViewModel}" Spacing="8">

                                <!-- Action type selector -->
                                <ComboBox ItemsSource="{Binding AvailableActionTypes}"
                                          SelectedItem="{Binding SelectedActionType}"
                                          HorizontalAlignment="Stretch" />

                                <!-- Keyboard -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsKeyboardAction}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="KEY COMBINATION" FontSize="11" FontWeight="Bold" />
                                        <TextBlock Text="Click field, then press keys" FontSize="10" Opacity="0.6" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Border Grid.Column="0"
                                                    Background="{Binding KeyCaptureBackground}"
                                                    BorderBrush="{Binding KeyCaptureBorderBrush}"
                                                    BorderThickness="2" CornerRadius="4" Padding="8,5"
                                                    Margin="0,0,6,0" Cursor="Hand" Focusable="True"
                                                    Name="ShortPressKeyCaptureField"
                                                    Tag="{Binding #ProfileEditorRoot.DataContext.ButtonConfigViewModel}"
                                                    PointerPressed="OnKeyCaptureFieldPressed"
                                                    KeyDown="OnKeyCaptureKeyDown"
                                                    KeyUp="OnKeyCaptureKeyUp"
                                                    TextInput="OnKeyCaptureTextInput">
                                                <TextBlock Text="{Binding KeySequenceDisplay}"
                                                           VerticalAlignment="Center" FontSize="11" />
                                            </Border>
                                            <Button Grid.Column="1" Content="{Binding KeyCaptureButtonText}"
                                                    Width="76" Command="{Binding ToggleKeyCaptureCommand}"
                                                    VerticalAlignment="Stretch" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                    IsVisible="{Binding HasCapturedKeys}">
                                            <TextBlock Text="Mod:" Opacity="0.6" VerticalAlignment="Center" FontSize="10" />
                                            <TextBlock Text="{Binding CapturedModifiersText}" FontWeight="Bold" FontSize="10" />
                                            <TextBlock Text="Key:" Opacity="0.6" VerticalAlignment="Center" FontSize="10" Margin="6,0,0,0" />
                                            <TextBlock Text="{Binding CapturedKeyText}" FontWeight="Bold" FontSize="10" />
                                        </StackPanel>
                                        <Separator Margin="0,2" />
                                        <TextBlock Text="Or enter text:" FontSize="10" Opacity="0.6" />
                                        <TextBox Text="{Binding TextToType}"
                                                 PlaceholderText="Hello World"
                                                 IsEnabled="{Binding !IsCapturingKeys}" />
                                    </StackPanel>
                                </Border>

                                <!-- Media -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsMediaAction}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="MEDIA KEY" FontSize="11" FontWeight="Bold" />
                                        <ComboBox ItemsSource="{Binding AvailableMediaKeys}"
                                                  SelectedItem="{Binding SelectedMediaKey}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Border>

                                <!-- Profile Switch -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsProfileSwitchAction}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="TARGET PROFILE" FontSize="11" FontWeight="Bold" />
                                        <ComboBox ItemsSource="{Binding AvailableProfiles}"
                                                  SelectedItem="{Binding SelectedTargetProfile}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Border>

                                <!-- Folder -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsFolderAction}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="FOLDER" FontSize="11" FontWeight="Bold" />
                                        <TextBlock Text="Folder name:" FontSize="10" Opacity="0.7" />
                                        <TextBox Text="{Binding FolderName}" PlaceholderText="My Folder" />
                                        <TextBlock Text="📁 Created automatically on save"
                                                   FontSize="10" Opacity="0.5" Foreground="#00FFAA" />
                                    </StackPanel>
                                </Border>

                                <!-- Custom HID -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsCustomHidAction}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="CUSTOM HID" FontSize="11" FontWeight="Bold" />
                                        <TextBlock Text="Report bytes (hex, space-separated):" FontSize="10" Opacity="0.7" />
                                        <TextBox Text="{Binding CustomHidData}"
                                                 PlaceholderText="FF 00 A0 …"
                                                 FontFamily="Consolas, monospace" />
                                    </StackPanel>
                                </Border>

                                <!-- Plugin -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsPluginAction}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="PLUGIN ACTION" FontSize="11" FontWeight="Bold" />
                                        <TextBlock Text="{Binding PluginId}" FontSize="10" Opacity="0.6" />
                                        <TextBlock Text="{Binding PluginActionId}" FontSize="11" />
                                        <TextBlock Text="Settings (JSON):" FontSize="10" Opacity="0.7" />
                                        <TextBox Text="{Binding PluginSettings}"
                                                 AcceptsReturn="True" Height="70"
                                                 PlaceholderText="{}"
                                                 FontFamily="Consolas, monospace" />
                                    </StackPanel>
                                </Border>

                                <!-- Shell -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsShellAction}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="SHELL COMMAND" FontSize="11" FontWeight="Bold" />
                                        <TextBox Text="{Binding ShellCommand}"
                                                 PlaceholderText="git push, npm run build…"
                                                 FontFamily="Consolas, monospace" />
                                        <TextBlock Text="Working directory:" FontSize="10" Opacity="0.7" />
                                        <TextBox Text="{Binding ShellWorkingDirectory}"
                                                 PlaceholderText="/home/user/project" />
                                        <CheckBox IsChecked="{Binding ShellWaitForExit}"
                                                  Content="Wait for exit" FontSize="11" />
                                    </StackPanel>
                                </Border>

                                <!-- Launch App -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsLaunchAppAction}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="LAUNCH APPLICATION" FontSize="11" FontWeight="Bold" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0" Text="{Binding LaunchAppPath}"
                                                     PlaceholderText="Path to executable…"
                                                     Margin="0,0,6,0" />
                                            <Button Grid.Column="1" Content="📂"
                                                    Command="{Binding BrowseLaunchAppCommand}" Width="36" />
                                        </Grid>
                                        <TextBox Text="{Binding LaunchAppArguments}"
                                                 PlaceholderText="--flag value (optional)" />
                                    </StackPanel>
                                </Border>

                                <!-- Sequence -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding IsSequenceAction}">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="ACTION SEQUENCE" FontSize="11" FontWeight="Bold" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SequenceSteps.Count, StringFormat='{}{0}/16'}"
                                                       Opacity="0.7" FontSize="11" />
                                        </Grid>
                                        <Border Background="#0C0C18" CornerRadius="4" Padding="5" MinHeight="50">
                                            <ScrollViewer MaxHeight="160">
                                                <ItemsControl ItemsSource="{Binding SequenceSteps}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#1A1A2E" CornerRadius="4"
                                                                    Padding="6" Margin="0,0,0,4">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{Binding StepNumber, StringFormat='#{0}'}"
                                                                                   FontWeight="Bold" Opacity="0.5"
                                                                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                        <ComboBox Grid.Column="1"
                                                                                  ItemsSource="{Binding AvailableActionTypes}"
                                                                                  SelectedItem="{Binding ActionType}"
                                                                                  HorizontalAlignment="Stretch" Margin="0,0,3,0" />
                                                                        <Button Grid.Column="2" Content="▲" Width="22" Height="22" Margin="2,0"
                                                                                Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).MoveStepUpCommand}"
                                                                                CommandParameter="{Binding}" />
                                                                        <Button Grid.Column="3" Content="▼" Width="22" Height="22" Margin="2,0"
                                                                                Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).MoveStepDownCommand}"
                                                                                CommandParameter="{Binding}" />
                                                                        <Button Grid.Column="4" Content="✕" Width="22" Height="22" Margin="2,0,0,0"
                                                                                Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).RemoveSequenceStepCommand}"
                                                                                CommandParameter="{Binding}" />
                                                                    </Grid>
                                                                    <StackPanel IsVisible="{Binding IsKeyboardStep}" Spacing="3">
                                                                        <Grid ColumnDefinitions="*,Auto">
                                                                            <Border Grid.Column="0"
                                                                                    Background="#2A2A3E" BorderBrush="#555"
                                                                                    BorderThickness="1" CornerRadius="3" Padding="5,3"
                                                                                    Margin="0,0,3,0" Cursor="Hand" Focusable="True"
                                                                                    PointerPressed="OnSequenceStepKeyCapturePressed"
                                                                                    KeyDown="OnSequenceStepKeyDown"
                                                                                    KeyUp="OnSequenceStepKeyUp"
                                                                                    TextInput="OnSequenceStepTextInput"
                                                                                    Tag="{Binding}">
                                                                                <TextBlock Text="{Binding KeySequenceDisplay}" FontSize="10" />
                                                                            </Border>
                                                                            <Button Grid.Column="1"
                                                                                    Content="{Binding KeyCaptureButtonText}"
                                                                                    FontSize="10" Width="48" Height="22"
                                                                                    Tag="{Binding}"
                                                                                    Click="OnSequenceStepToggleCapture" />
                                                                        </Grid>
                                                                        <TextBox Text="{Binding KeyboardText}"
                                                                                 PlaceholderText="Or type text…" FontSize="10" />
                                                                    </StackPanel>
                                                                    <StackPanel IsVisible="{Binding IsShellStep}">
                                                                        <TextBox Text="{Binding ShellCommand}"
                                                                                 PlaceholderText="Command…" FontSize="11" />
                                                                    </StackPanel>
                                                                    <StackPanel IsVisible="{Binding IsDelayStep}"
                                                                                Orientation="Horizontal" Spacing="4">
                                                                        <NumericUpDown Value="{Binding DelayMs}"
                                                                                       Minimum="0" Maximum="60000"
                                                                                       Increment="100" Width="90"
                                                                                       FormatString="0" FontSize="11" />
                                                                        <TextBlock Text="ms" FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                    <StackPanel IsVisible="{Binding IsCustomHidStep}">
                                                                        <TextBox Text="{Binding CustomHidData}"
                                                                                 PlaceholderText="HEX…" FontSize="11" />
                                                                    </StackPanel>
                                                                    <StackPanel IsVisible="{Binding IsProfileSwitchStep}"
                                                                                Orientation="Horizontal" Spacing="4">
                                                                        <TextBlock Text="Profile:" FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
                                                                        <ComboBox ItemsSource="{Binding AvailableProfileIds}"
                                                                                  SelectedItem="{Binding TargetProfileId}" Width="70" />
                                                                    </StackPanel>
                                                                    <StackPanel IsVisible="{Binding IsFolderStep}"
                                                                                Orientation="Horizontal" Spacing="4">
                                                                        <TextBlock Text="Folder:" FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
                                                                        <ComboBox ItemsSource="{Binding AvailableFolderIds}"
                                                                                  SelectedItem="{Binding FolderId}" Width="70" />
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <TextBlock Text="Delay before:" FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                                        <NumericUpDown Value="{Binding DelayBeforeMs}"
                                                                                       Minimum="0" Maximum="10000"
                                                                                       Increment="50" Width="70"
                                                                                       FormatString="0" FontSize="10" />
                                                                        <TextBlock Text="ms" FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                        <Button Content="+ ADD STEP"
                                                Command="{Binding AddSequenceStepCommand}"
                                                IsEnabled="{Binding CanAddMoreSteps}"
                                                HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>

                                <!-- Button Name -->
                                <Border Background="#161B22" CornerRadius="4" Padding="10"
                                        IsVisible="{Binding !IsLongPress}">
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="BUTTON NAME" FontSize="11" FontWeight="Bold" />
                                        <TextBlock Text="Shown on device when no image. Leave empty to auto-generate."
                                                   FontSize="10" Opacity="0.6" TextWrapping="Wrap" />
                                        <TextBox Text="{Binding ButtonName}"
                                                 PlaceholderText="e.g. Git Push, Volume Up…" />
                                    </StackPanel>
                                </Border>

                                <!-- Image -->
                                <StackPanel Spacing="5" IsVisible="{Binding !IsLongPress}">
                                    <TextBlock Text="IMAGE:" FontSize="11" Opacity="0.7" />
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding ImagePath}"
                                                 PlaceholderText="Path to image (160×160 JPEG)"
                                                 Margin="0,0,5,0" />
                                        <Button Grid.Column="1" Content="…"
                                                Command="{Binding BrowseImageCommand}" Width="34" />
                                        <Button Grid.Column="2" Content="✕"
                                                Command="{Binding ClearImageCommand}"
                                                Width="34" Margin="4,0,0,0"
                                                IsVisible="{Binding HasImagePreview}" />
                                    </Grid>
                                    <Border Background="#0C0C18" CornerRadius="5" Padding="6"
                                            IsVisible="{Binding HasImagePreview}"
                                            HorizontalAlignment="Left">
                                        <Image Source="{Binding ImagePreview}"
                                               Width="72" Height="72" Stretch="Uniform" />
                                    </Border>
                                </StackPanel>

                                <!-- LED Color -->
                                <StackPanel Spacing="5" IsVisible="{Binding !IsLongPress}">
                                    <TextBlock Text="LED COLOR:" FontSize="11" Opacity="0.7" />
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Width="26" Height="26"
                                                CornerRadius="4" BorderBrush="#555" BorderThickness="1"
                                                Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding LedColorPreview}" />
                                            </Border.Background>
                                        </Border>
                                        <TextBox Grid.Column="1" Text="{Binding LedColorHex}"
                                                 PlaceholderText="#FFFFFF" VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Content="🎨" Margin="5,0,0,0"
                                                Command="{Binding ToggleColorPickerCommand}" Width="34" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Brightness:" Opacity="0.7"
                                                   VerticalAlignment="Center" Width="68" />
                                        <Slider Minimum="0" Maximum="100"
                                                Value="{Binding Brightness}"
                                                Width="120" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Brightness, StringFormat={}{0:F0}}"
                                                   VerticalAlignment="Center" Width="26" />
                                    </StackPanel>
                                    <Border Background="#0C0C18" CornerRadius="4" Padding="8"
                                            IsVisible="{Binding IsColorPickerVisible}">
                                        <StackPanel Spacing="6">
                                            <ColorView Color="{Binding LedColor}"
                                                       IsAlphaVisible="False"
                                                       HorizontalAlignment="Left" />
                                            <Button Content="Done" HorizontalAlignment="Center" Width="72"
                                                    Command="{Binding ToggleColorPickerCommand}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                            </StackPanel>
                            <!-- end SHORT PRESS DataContext block -->

                            <!-- ══ LONG PRESS section (hidden for encoder) ══ -->
                            <StackPanel IsVisible="{Binding LongPressConfigViewModel, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Spacing="8" Margin="0,10,0,0">
                                <Separator />
                                <TextBlock Text="LONG PRESS"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#00FF41" Opacity="0.8"
                                           Margin="0,2,0,4" />

                                <StackPanel DataContext="{Binding LongPressConfigViewModel}" Spacing="8">

                                    <ComboBox ItemsSource="{Binding AvailableActionTypes}"
                                              SelectedItem="{Binding SelectedActionType}"
                                              HorizontalAlignment="Stretch" />

                                    <!-- Long press — Keyboard -->
                                    <Border Background="#161B22" CornerRadius="4" Padding="10"
                                            IsVisible="{Binding IsKeyboardAction}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="KEY COMBINATION" FontSize="11" FontWeight="Bold" />
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Border Grid.Column="0"
                                                        Background="{Binding KeyCaptureBackground}"
                                                        BorderBrush="{Binding KeyCaptureBorderBrush}"
                                                        BorderThickness="2" CornerRadius="4" Padding="8,5"
                                                        Margin="0,0,6,0" Cursor="Hand" Focusable="True"
                                                        Name="LongPressKeyCaptureField"
                                                        Tag="{Binding #ProfileEditorRoot.DataContext.LongPressConfigViewModel}"
                                                        PointerPressed="OnKeyCaptureFieldPressed"
                                                        KeyDown="OnKeyCaptureKeyDown"
                                                        KeyUp="OnKeyCaptureKeyUp"
                                                        TextInput="OnKeyCaptureTextInput">
                                                    <TextBlock Text="{Binding KeySequenceDisplay}"
                                                               VerticalAlignment="Center" FontSize="11" />
                                                </Border>
                                                <Button Grid.Column="1" Content="{Binding KeyCaptureButtonText}"
                                                        Width="76" Command="{Binding ToggleKeyCaptureCommand}"
                                                        VerticalAlignment="Stretch" />
                                            </Grid>
                                            <TextBlock Text="Or enter text:" FontSize="10" Opacity="0.6" />
                                            <TextBox Text="{Binding TextToType}"
                                                     PlaceholderText="Hello World"
                                                     IsEnabled="{Binding !IsCapturingKeys}" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Long press — Media -->
                                    <Border Background="#161B22" CornerRadius="4" Padding="10"
                                            IsVisible="{Binding IsMediaAction}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="MEDIA KEY" FontSize="11" FontWeight="Bold" />
                                            <ComboBox ItemsSource="{Binding AvailableMediaKeys}"
                                                      SelectedItem="{Binding SelectedMediaKey}"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Long press — Shell -->
                                    <Border Background="#161B22" CornerRadius="4" Padding="10"
                                            IsVisible="{Binding IsShellAction}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="SHELL COMMAND" FontSize="11" FontWeight="Bold" />
                                            <TextBox Text="{Binding ShellCommand}"
                                                     PlaceholderText="Command…"
                                                     FontFamily="Consolas, monospace" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Long press — Launch App -->
                                    <Border Background="#161B22" CornerRadius="4" Padding="10"
                                            IsVisible="{Binding IsLaunchAppAction}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="LAUNCH APPLICATION" FontSize="11" FontWeight="Bold" />
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding LaunchAppPath}"
                                                         PlaceholderText="Path to executable…"
                                                         Margin="0,0,6,0" />
                                                <Button Grid.Column="1" Content="📂"
                                                        Command="{Binding BrowseLaunchAppCommand}" Width="36" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Long press — Custom HID -->
                                    <Border Background="#161B22" CornerRadius="4" Padding="10"
                                            IsVisible="{Binding IsCustomHidAction}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="CUSTOM HID" FontSize="11" FontWeight="Bold" />
                                            <TextBox Text="{Binding CustomHidData}"
                                                     PlaceholderText="FF 00 A0 …"
                                                     FontFamily="Consolas, monospace" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Long press — Profile Switch -->
                                    <Border Background="#161B22" CornerRadius="4" Padding="10"
                                            IsVisible="{Binding IsProfileSwitchAction}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="TARGET PROFILE" FontSize="11" FontWeight="Bold" />
                                            <ComboBox ItemsSource="{Binding AvailableProfiles}"
                                                      SelectedItem="{Binding SelectedTargetProfile}"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Long press name -->
                                    <Border Background="#161B22" CornerRadius="4" Padding="10">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="LONG PRESS NAME" FontSize="11" FontWeight="Bold" />
                                            <TextBox Text="{Binding ButtonName}"
                                                     PlaceholderText="Optional label for long press…" />
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                                <!-- end LONG PRESS DataContext block -->
                            </StackPanel>

                            <Separator Margin="0,10,0,6" />

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save / Cancel (pinned bottom) -->
                    <Border Grid.Row="1"
                            Background="#0D1117" Padding="10,8"
                            BorderBrush="#222" BorderThickness="0,1,0,0"
                            IsVisible="{Binding ButtonConfigViewModel, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Command="{Binding CloseButtonConfigCommand}" />
                            <Button Content="💾 Save"
                                    Command="{Binding SaveButtonConfigCommand}"
                                    Background="#0D4429" BorderBrush="#00FF00" />
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

        </Grid>
        <!-- end ROW 1 -->

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 2 — STATUS BAR
        ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#0D1117" CornerRadius="6"
                BorderBrush="#222" BorderThickness="1"
                Padding="12,5" Margin="0,8,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Connection dot -->
                <Ellipse Grid.Column="0" Width="8" Height="8"
                         Margin="0,0,8,0" VerticalAlignment="Center"
                         Fill="#00FF41" />
                <!-- Status message -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           FontSize="11" Opacity="0.8"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <!-- Sync progress -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding IsSyncing}">
                    <ProgressBar IsIndeterminate="True" Width="80" Height="6" VerticalAlignment="Center" />
                    <TextBlock Text="Syncing…" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
