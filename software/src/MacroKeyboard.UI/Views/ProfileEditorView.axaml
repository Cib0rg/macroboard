<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MacroKeyboard.UI.ViewModels"
             xmlns:conv="using:MacroKeyboard.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="MacroKeyboard.UI.Views.ProfileEditorView"
             x:DataType="vm:ProfileEditorViewModel"
             x:Name="ProfileEditorRoot">

    <UserControl.Resources>
        <conv:ObjectEqualityConverter x:Key="ObjectEqualityConverter" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="240,*,200" Margin="10">
        <!-- Left Panel - Profile List -->
        <Border Grid.Column="0" Padding="12" Margin="0,0,5,0"
                Background="#0D1117" CornerRadius="8"
                BorderBrush="#00FFFF" BorderThickness="1">
            <StackPanel Spacing="10">
                <TextBlock Text="📂 PROFILES" FontSize="16" FontWeight="Bold" Foreground="#00FFFF" />
                
                <Separator />
                
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Height="250">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <StackPanel Spacing="6">
                    <Button Content="+ NEW"
                            Command="{Binding CreateNewProfileCommand}"
                            HorizontalAlignment="Stretch" />
                    <Button Content="💾 SAVE"
                            Command="{Binding SaveProfileCommand}"
                            HorizontalAlignment="Stretch" />
                    <Button Content="📂 LOAD"
                            Command="{Binding LoadProfileCommand}"
                            HorizontalAlignment="Stretch" />
                    <Button Content="🗑 DELETE"
                            Command="{Binding DeleteProfileCommand}"
                            HorizontalAlignment="Stretch" />
                    
                    <Separator />
                    
                    <Button Content="📤 SEND TO DEVICE"
                            Command="{Binding SendToDeviceCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#0D4429"
                            BorderBrush="#00FF00" />
                    <Button Content="📥 FROM DEVICE"
                            Command="{Binding LoadFromDeviceCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#1A3A5C"
                            BorderBrush="#00AAFF" />
                </StackPanel>
                
                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="10"
                           TextWrapping="Wrap"
                           Opacity="0.8"
                           Foreground="#FFA500" />
                
                <ProgressBar IsIndeterminate="True" 
                             IsVisible="{Binding IsSyncing}" />
            </StackPanel>
        </Border>

        <!-- Center Panel - Buttons List with inline config -->
        <Border Grid.Column="1" Padding="12" Margin="5,0"
                Background="#0D1117" CornerRadius="8"
                BorderBrush="#00FFFF" BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,Auto,*">
                <!-- Row 0: Header -->
                <StackPanel Grid.Row="0" Spacing="4" IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="⌨ BUTTONS" FontSize="16" FontWeight="Bold" Foreground="#00FFFF" />
                    
                    <!-- Profile Name -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="NAME:" Opacity="0.7" VerticalAlignment="Center" FontSize="11" />
                        <TextBox Text="{Binding SelectedProfile.Name}" 
                                 PlaceholderText="Profile name..."
                                 MinWidth="150" />
                    </StackPanel>
                </StackPanel>
                
                <Separator Grid.Row="1" Margin="0,8" />
                
                <TextBlock Grid.Row="2" Text="Drag an action from the palette onto a button"
                           FontSize="11" Opacity="0.6" Margin="0,0,0,8" />
                
                <!-- Row 3: Buttons List with inline config under each button -->
                <ScrollViewer Grid.Row="3">
                    <ItemsControl ItemsSource="{Binding FlattenedButtons}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FlattenedButtonItem">
                                <StackPanel>
                                    <!-- Button row -->
                                    <Border Background="#161B22"
                                            BorderBrush="#00FFFF"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,6"
                                            Margin="{Binding Margin}"
                                            MinHeight="36"
                                            DragDrop.AllowDrop="True"
                                            Tag="{Binding}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Button Grid.Column="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Command="{Binding #ProfileEditorRoot.DataContext.ConfigureFlattenedButtonCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="{Binding Label}"
                                                           VerticalAlignment="Center"
                                                           FontSize="12" />
                                            </Button>
                                            <TextBlock Grid.Column="1"
                                                       Text="📁"
                                                       IsVisible="{Binding IsFolderHeader}"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Inline config panel (visible only for the configured button) -->
                                    <Border Padding="12" Margin="10,4,2,8"
                                            Background="#0A0E14" CornerRadius="6"
                                            BorderBrush="#00AAFF" BorderThickness="1"
                                            DragDrop.AllowDrop="True">
                                        <Border.IsVisible>
                                            <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                <Binding Path="Button" />
                                                <Binding Path="#ProfileEditorRoot.DataContext.ConfiguredButtonConfig" />
                                            </MultiBinding>
                                        </Border.IsVisible>
                                        <StackPanel Spacing="12" DataContext="{Binding #ProfileEditorRoot.DataContext.ButtonConfigViewModel}">
                                            <!-- Header -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding CurrentActionIcon}" FontSize="20" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding CurrentActionDisplayName}"
                                                               FontSize="14" FontWeight="Bold" Foreground="#00FFFF"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="← drag to change"
                                                               FontSize="10" Opacity="0.4"
                                                               VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="✕" Width="28" Height="28"
                                                        Command="{Binding #ProfileEditorRoot.DataContext.CloseButtonConfigCommand}" />
                                            </Grid>
                                            
                                            <Separator />

                                            <!-- Keyboard: Key Capture -->
                                            <Border Background="#161B22" CornerRadius="4" Padding="10"
                                                    IsVisible="{Binding IsKeyboardAction}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="KEY COMBINATION" FontSize="12" FontWeight="Bold" />
                                                    <TextBlock Text="Click field and press keys to capture"
                                                               FontSize="10" Opacity="0.6" />
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Border Grid.Column="0"
                                                                Background="{Binding KeyCaptureBackground}"
                                                                BorderBrush="{Binding KeyCaptureBorderBrush}"
                                                                BorderThickness="2"
                                                                CornerRadius="4"
                                                                Padding="8,6"
                                                                Margin="0,0,6,0"
                                                                Cursor="Hand"
                                                                PointerPressed="OnKeyCaptureFieldPressed"
                                                                Focusable="True"
                                                                Name="KeyCaptureField"
                                                                KeyDown="OnKeyCaptureKeyDown"
                                                                KeyUp="OnKeyCaptureKeyUp"
                                                                TextInput="OnKeyCaptureTextInput">
                                                            <TextBlock Text="{Binding KeySequenceDisplay}"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="12" />
                                                        </Border>
                                                        <Button Grid.Column="1"
                                                                Content="{Binding KeyCaptureButtonText}"
                                                                Width="80"
                                                                Command="{Binding ToggleKeyCaptureCommand}"
                                                                VerticalAlignment="Stretch" />
                                                    </Grid>
                                                    
                                                    <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding HasCapturedKeys}">
                                                        <TextBlock Text="Mod:" Opacity="0.6" VerticalAlignment="Center" FontSize="10" />
                                                        <TextBlock Text="{Binding CapturedModifiersText}" FontWeight="Bold" FontSize="10" />
                                                        <TextBlock Text="Key:" Opacity="0.6" VerticalAlignment="Center" FontSize="10" Margin="8,0,0,0" />
                                                        <TextBlock Text="{Binding CapturedKeyText}" FontWeight="Bold" FontSize="10" />
                                                    </StackPanel>
                                                    
                                                    <Separator Margin="0,4" />
                                                    <TextBlock Text="Or enter text:" FontSize="10" Opacity="0.6" />
                                                    <TextBox Text="{Binding TextToType}"
                                                             PlaceholderText="Hello World"
                                                             IsEnabled="{Binding !IsCapturingKeys}" />
                                                </StackPanel>
                                            </Border>

                                            <!-- ProfileSwitch -->
                                            <Border Background="#161B22" CornerRadius="4" Padding="10"
                                                    IsVisible="{Binding IsProfileSwitchAction}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="TARGET PROFILE" FontSize="12" FontWeight="Bold" />
                                                    <ComboBox ItemsSource="{Binding AvailableProfiles}"
                                                              SelectedItem="{Binding SelectedTargetProfile}"
                                                              HorizontalAlignment="Stretch"
                                                              PlaceholderText="Select profile..." />
                                                </StackPanel>
                                            </Border>

                                            <!-- Folder -->
                                            <Border Background="#161B22" CornerRadius="4" Padding="10"
                                                    IsVisible="{Binding IsFolderAction}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="FOLDER" FontSize="12" FontWeight="Bold" />
                                                    <TextBlock Text="Folder name:" FontSize="10" Opacity="0.7" />
                                                    <TextBox Text="{Binding FolderName}"
                                                             PlaceholderText="My Folder" />
                                                    <TextBlock Text="📁 Folder will be created automatically"
                                                               FontSize="10" Opacity="0.5" Foreground="#00FFAA" />
                                                </StackPanel>
                                            </Border>

                                            <!-- CustomHID -->
                                            <Border Background="#161B22" CornerRadius="4" Padding="10"
                                                    IsVisible="{Binding IsCustomHidAction}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="CUSTOM HID" FontSize="12" FontWeight="Bold" />
                                                    <TextBlock Text="Custom HID report (coming soon)" FontSize="10" Opacity="0.6" />
                                                </StackPanel>
                                            </Border>

                                            <!-- Shell Command -->
                                            <Border Background="#161B22" CornerRadius="4" Padding="10"
                                                    IsVisible="{Binding IsShellAction}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="SHELL COMMAND" FontSize="12" FontWeight="Bold" />
                                                    <TextBlock Text="Command:" FontSize="10" Opacity="0.7" />
                                                    <TextBox Text="{Binding ShellCommand}"
                                                             PlaceholderText="git push, npm run build..."
                                                             FontFamily="Consolas, monospace" />
                                                    <TextBlock Text="Working directory:" FontSize="10" Opacity="0.7" />
                                                    <TextBox Text="{Binding ShellWorkingDirectory}"
                                                             PlaceholderText="/home/user/project" />
                                                    <CheckBox IsChecked="{Binding ShellWaitForExit}"
                                                              Content="Wait for exit" FontSize="11" />
                                                    <TextBlock Text="⚠️ Runs on PC via Backend"
                                                               FontSize="10" Opacity="0.6" Foreground="#FFA500" />
                                                </StackPanel>
                                            </Border>

                                            <!-- Launch App -->
                                            <Border Background="#161B22" CornerRadius="4" Padding="10"
                                                    IsVisible="{Binding IsLaunchAppAction}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="LAUNCH APPLICATION" FontSize="12" FontWeight="Bold" />
                                                    <TextBlock Text="Application:" FontSize="10" Opacity="0.7" />
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBox Grid.Column="0" Text="{Binding LaunchAppPath}"
                                                                 PlaceholderText="Path to executable..."
                                                                 Margin="0,0,6,0" />
                                                        <Button Grid.Column="1" Content="📂"
                                                                Command="{Binding BrowseLaunchAppCommand}" Width="36" />
                                                    </Grid>
                                                    <TextBlock Text="Arguments (optional):" FontSize="10" Opacity="0.7" />
                                                    <TextBox Text="{Binding LaunchAppArguments}"
                                                             PlaceholderText="--flag value" />
                                                    <TextBlock Text="Working directory (optional):" FontSize="10" Opacity="0.7" />
                                                    <TextBox Text="{Binding LaunchAppWorkingDirectory}"
                                                             PlaceholderText="Leave empty for app directory" />
                                                    <TextBlock Text="🚀 App icon will be used as button image"
                                                               FontSize="10" Opacity="0.6" Foreground="#00FFAA" />
                                                </StackPanel>
                                            </Border>

                                            <!-- Sequence Editor -->
                                            <Border Background="#161B22" CornerRadius="4" Padding="10"
                                                    IsVisible="{Binding IsSequenceAction}">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="ACTION SEQUENCE" FontSize="12" FontWeight="Bold" />
                                                        <TextBlock Grid.Column="1" 
                                                                   Text="{Binding SequenceSteps.Count, StringFormat='{}{0}/16'}"
                                                                   Opacity="0.7" FontSize="11" />
                                                    </Grid>
                                                    
                                                    <Border Background="#0C0C18" CornerRadius="4" Padding="6" MinHeight="80">
                                                        <ScrollViewer MaxHeight="180">
                                                            <ItemsControl ItemsSource="{Binding SequenceSteps}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="#1A1A2E" CornerRadius="4" Padding="6" Margin="0,0,0,6">
                                                                            <StackPanel Spacing="4">
                                                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                                                                    <TextBlock Grid.Column="0"
                                                                                               Text="{Binding StepNumber, StringFormat='#{0}'}"
                                                                                               FontWeight="Bold" Opacity="0.5"
                                                                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                                    <ComboBox Grid.Column="1"
                                                                                              ItemsSource="{Binding AvailableActionTypes}"
                                                                                              SelectedItem="{Binding ActionType}"
                                                                                              HorizontalAlignment="Stretch" Margin="0,0,4,0" />
                                                                                    <Button Grid.Column="2" Content="▲" Width="24" Height="24" Margin="2,0"
                                                                                            Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).MoveStepUpCommand}"
                                                                                            CommandParameter="{Binding}" />
                                                                                    <Button Grid.Column="3" Content="▼" Width="24" Height="24" Margin="2,0"
                                                                                            Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).MoveStepDownCommand}"
                                                                                            CommandParameter="{Binding}" />
                                                                                    <Button Grid.Column="4" Content="✕" Width="24" Height="24" Margin="2,0,0,0"
                                                                                            Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).RemoveSequenceStepCommand}"
                                                                                            CommandParameter="{Binding}" />
                                                                                </Grid>
                                                                                
                                                                                <StackPanel IsVisible="{Binding IsKeyboardStep}" Spacing="4">
                                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                                        <Border Grid.Column="0"
                                                                                                Background="#2A2A3E"
                                                                                                BorderBrush="#555"
                                                                                                BorderThickness="1"
                                                                                                CornerRadius="3"
                                                                                                Padding="6,4"
                                                                                                Margin="0,0,4,0"
                                                                                                Cursor="Hand"
                                                                                                Focusable="True"
                                                                                                PointerPressed="OnSequenceStepKeyCapturePressed"
                                                                                                KeyDown="OnSequenceStepKeyDown"
                                                                                                KeyUp="OnSequenceStepKeyUp"
                                                                                                TextInput="OnSequenceStepTextInput"
                                                                                                Tag="{Binding}">
                                                                                            <TextBlock Text="{Binding KeySequenceDisplay}" FontSize="10" />
                                                                                        </Border>
                                                                                        <Button Grid.Column="1"
                                                                                                Content="{Binding KeyCaptureButtonText}"
                                                                                                FontSize="10" Width="50" Height="22"
                                                                                                Tag="{Binding}"
                                                                                                Click="OnSequenceStepToggleCapture" />
                                                                                    </Grid>
                                                                                    <TextBox Text="{Binding KeyboardText}" PlaceholderText="Or type text..." FontSize="10" />
                                                                                </StackPanel>
                                                                                <StackPanel IsVisible="{Binding IsShellStep}">
                                                                                    <TextBox Text="{Binding ShellCommand}" PlaceholderText="Command..." FontSize="11" />
                                                                                </StackPanel>
                                                                                <StackPanel IsVisible="{Binding IsDelayStep}" Orientation="Horizontal" Spacing="4">
                                                                                    <NumericUpDown Value="{Binding DelayMs}" Minimum="0" Maximum="60000"
                                                                                                   Increment="100" Width="100" FormatString="0" FontSize="11" />
                                                                                    <TextBlock Text="ms" FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
                                                                                </StackPanel>
                                                                                <StackPanel IsVisible="{Binding IsCustomHidStep}">
                                                                                    <TextBox Text="{Binding CustomHidData}" PlaceholderText="HEX..." FontSize="11" />
                                                                                </StackPanel>
                                                                                <StackPanel IsVisible="{Binding IsProfileSwitchStep}" Orientation="Horizontal" Spacing="4">
                                                                                    <TextBlock Text="Profile:" FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
                                                                                    <ComboBox ItemsSource="{Binding AvailableProfileIds}" SelectedItem="{Binding TargetProfileId}" Width="80" />
                                                                                </StackPanel>
                                                                                <StackPanel IsVisible="{Binding IsFolderStep}" Orientation="Horizontal" Spacing="4">
                                                                                    <TextBlock Text="Folder:" FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
                                                                                    <ComboBox ItemsSource="{Binding AvailableFolderIds}" SelectedItem="{Binding FolderId}" Width="80" />
                                                                                </StackPanel>
                                                                                
                                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                                    <TextBlock Text="Delay before:" FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                                                    <NumericUpDown Value="{Binding DelayBeforeMs}" Minimum="0" Maximum="10000"
                                                                                                   Increment="50" Width="80" FormatString="0" FontSize="10" />
                                                                                    <TextBlock Text="ms" FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                                                </StackPanel>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </ScrollViewer>
                                                    </Border>
                                                    
                                                    <Button Content="+ ADD STEP"
                                                            Command="{Binding AddSequenceStepCommand}"
                                                            IsEnabled="{Binding CanAddMoreSteps}"
                                                            HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Border>

                                            <!-- Image -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="IMAGE:" FontSize="11" Opacity="0.7" />
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBox Grid.Column="0" Text="{Binding ImagePath}"
                                                             PlaceholderText="Path to image (160x160 JPEG)"
                                                             Margin="0,0,6,0" />
                                                    <Button Grid.Column="1" Content="..."
                                                            Command="{Binding BrowseImageCommand}" Width="36" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- LED Color -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="LED COLOR:" FontSize="11" Opacity="0.7" />
                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <Border Grid.Column="0" Width="28" Height="28"
                                                            CornerRadius="4" BorderBrush="#555" BorderThickness="1"
                                                            Margin="0,0,6,0" VerticalAlignment="Center">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding LedColorPreview}" />
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Text="{Binding LedColorHex}"
                                                             PlaceholderText="#FFFFFF" VerticalAlignment="Center" />
                                                    <Button Grid.Column="2" Content="🎨" Margin="6,0,0,0"
                                                            Command="{Binding ToggleColorPickerCommand}" Width="36" />
                                                </Grid>
                                                
                                                <!-- Brightness Slider -->
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="Brightness:" Opacity="0.7"
                                                               VerticalAlignment="Center" Width="70" />
                                                    <Slider Minimum="0" Maximum="255"
                                                            Value="{Binding Brightness}"
                                                            Width="140" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Brightness, StringFormat={}{0:F0}}"
                                                               VerticalAlignment="Center" Width="30" />
                                                </StackPanel>
                                                
                                                <!-- ColorPicker вместо RGB Sliders -->
                                                <Border Background="#0C0C18" CornerRadius="4" Padding="10"
                                                        IsVisible="{Binding IsColorPickerVisible}">
                                                    <StackPanel Spacing="8">
                                                        <!-- Компактный ColorPicker -->
                                                        <ColorPicker Name="ColorPickerControl"
                                                                    Color="{Binding LedColor}"
                                                                    Width="200"
                                                                    Height="40"
                                                                    IsAlphaEnabled="False" />
                                                        
                                                        <!-- Кнопка Done -->
                                                        <Button Content="Done"
                                                                HorizontalAlignment="Center"
                                                                Width="80"
                                                                Command="{Binding ToggleColorPickerCommand}" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <Separator />

                                            <!-- Save / Cancel Buttons -->
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                                <Button Content="CANCEL"
                                                        Command="{Binding #ProfileEditorRoot.DataContext.CloseButtonConfigCommand}" />
                                                <Button Content="💾 SAVE"
                                                        Command="{Binding #ProfileEditorRoot.DataContext.SaveButtonConfigCommand}"
                                                        Background="#0D4429" BorderBrush="#00FF00" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <ProgressBar Grid.Row="3" IsIndeterminate="True" 
                             IsVisible="{Binding IsLoading}"
                             VerticalAlignment="Top" />
            </Grid>
        </Border>

        <!-- Right Panel - Actions Palette (drag source) -->
        <Border Grid.Column="2" Padding="12" Margin="5,0,0,0"
                Background="#0D1117" CornerRadius="8"
                BorderBrush="#00FFFF" BorderThickness="1">
            <StackPanel Spacing="10">
                <TextBlock Text="🎯 ACTIONS" FontSize="14" FontWeight="Bold" Foreground="#00FFFF" />
                <TextBlock Text="Drag onto a button" FontSize="10" Opacity="0.5" />
                
                <Separator />
                
                <ItemsControl ItemsSource="{Binding ActionPaletteItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ActionPaletteItem">
                            <Border Background="#161B22"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="0,0,0,6"
                                    BorderBrush="#00FFFF"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    PointerPressed="OnActionDragStarted"
                                    Tag="{Binding}"
                                    ToolTip.Tip="{Binding Description}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding IconText}" 
                                               FontSize="22"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
