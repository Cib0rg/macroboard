<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MacroKeyboard.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="MacroKeyboard.UI.Views.ProfileEditorView"
             x:DataType="vm:ProfileEditorViewModel"
             x:Name="ProfileEditorRoot">

    <Grid ColumnDefinitions="250,*" Margin="20">
        <!-- Left Panel - Profile List -->
        <Border Grid.Column="0"  Padding="16" Margin="0,0,10,0">
            <StackPanel Spacing="12">
                <TextBlock Text="Profiles" FontSize="18" FontWeight="Bold" />
                
                <Separator />
                
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Height="350"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <StackPanel Spacing="8">
                    <Button Content="New Profile"
                            Command="{Binding CreateNewProfileCommand}"
                            HorizontalAlignment="Stretch" />
                    <Button Content="💾 Save to File..."
                            Command="{Binding SaveProfileCommand}"
                            HorizontalAlignment="Stretch" />
                    <Button Content="📂 Load from File..."
                            Command="{Binding LoadProfileCommand}"
                            HorizontalAlignment="Stretch" />
                    <Button Content="🗑 Delete"
                            Command="{Binding DeleteProfileCommand}"
                            HorizontalAlignment="Stretch" />
                    
                    <Separator />
                    
                    <Button Content="📤 Send to Device"
                            Command="{Binding SendToDeviceCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#0078D4"
                            Foreground="White" />
                    <Button Content="📥 Load from Device"
                            Command="{Binding LoadFromDeviceCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#107C10"
                            Foreground="White" />
                </StackPanel>
                
                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="11"
                           TextWrapping="Wrap"
                           Opacity="0.8" />
                
                <!-- Sync Progress -->
                <ProgressBar IsIndeterminate="True" 
                             IsVisible="{Binding IsSyncing}" />
            </StackPanel>
        </Border>

        <!-- Right Panel - Profile Editor -->
        <Border Grid.Column="1" Classes="PanelBorder" Padding="20">
            <ScrollViewer>
                <StackPanel Spacing="16" IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="Profile Editor" FontSize="20" FontWeight="Bold" />
                    
                    <Separator />
                    
                    <!-- Profile Name -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Profile Name:" />
                        <TextBox Text="{Binding SelectedProfile.Name}" 
                                 Watermark="Enter profile name..." />
                    </StackPanel>
                    
                    <!-- Buttons Tree (flat list with indentation for folders) -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Buttons:" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="Click a button to configure. Folder contents are shown indented below."
                                   FontSize="12" Opacity="0.7" />
                        
                        <ItemsControl ItemsSource="{Binding FlattenedButtons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="#3E3E42"
                                            CornerRadius="6"
                                            Padding="12,8"
                                            Margin="{Binding Margin}"
                                            MinHeight="44"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding #ProfileEditorRoot.DataContext.ConfigureFlattenedButtonCommand}"
                                            CommandParameter="{Binding}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="2"
                                                       Text="📁"
                                                       IsVisible="{Binding IsFolderHeader}"
                                                       VerticalAlignment="Center"
                                                       FontSize="16"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    
                    <!-- Loading Indicator -->
                    <ProgressBar IsIndeterminate="True" 
                                 IsVisible="{Binding IsLoading}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
