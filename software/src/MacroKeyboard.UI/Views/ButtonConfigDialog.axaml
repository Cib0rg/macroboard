<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MacroKeyboard.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="850"
        x:Class="MacroKeyboard.UI.Views.ButtonConfigDialog"
        x:DataType="vm:ButtonConfigDialogViewModel"
        Title="Configure Button"
        Width="700" Height="850"
        WindowStartupLocation="CenterOwner"
        Classes="Tron"
        CanResize="True">

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="{Binding ButtonConfig.ButtonId, StringFormat='Configure Button {0}'}"
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20" />

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16">
                <!-- Action Type -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Action Type" FontSize="16" FontWeight="Bold" />
                        <ComboBox ItemsSource="{Binding AvailableActionTypes}"
                                  SelectedItem="{Binding SelectedActionType}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>

                <!-- Keyboard: Key Capture -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16"
                        IsVisible="{Binding IsKeyboardAction}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Key Combination" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="Click the field below and press keys to capture (Ctrl, Shift, Alt, etc.)"
                                   FontSize="12" Opacity="0.7" />
                        <Grid ColumnDefinitions="*,Auto">
                            <!-- Key Capture Field -->
                            <Border Grid.Column="0"
                                    Background="{Binding KeyCaptureBackground}"
                                    BorderBrush="{Binding KeyCaptureBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"
                                    PointerPressed="OnKeyCaptureFieldPressed"
                                    Focusable="True"
                                    Name="KeyCaptureField"
                                    KeyDown="OnKeyCaptureKeyDown"
                                    KeyUp="OnKeyCaptureKeyUp">
                                <TextBlock Text="{Binding KeySequenceDisplay}"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas, Courier New, monospace"
                                           FontSize="14" />
                            </Border>
                            
                            <!-- Stop Recording Button -->
                            <Button Grid.Column="1"
                                    Content="{Binding KeyCaptureButtonText}"
                                    Width="120"
                                    Command="{Binding ToggleKeyCaptureCommand}"
                                    VerticalAlignment="Stretch" />
                        </Grid>
                        
                        <!-- Captured Keys Info -->
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasCapturedKeys}">
                            <TextBlock Text="Modifiers:" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CapturedModifiersText}" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Text="Key:" Opacity="0.7" VerticalAlignment="Center" Margin="16,0,0,0" />
                            <TextBlock Text="{Binding CapturedKeyText}" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <!-- Or enter text directly -->
                        <Separator Margin="0,8" />
                        <TextBlock Text="Or enter text to type:" FontSize="12" Opacity="0.7" />
                        <TextBox Text="{Binding TextToType}"
                                 PlaceholderText="e.g., Hello World"
                                 IsEnabled="{Binding !IsCapturingKeys}" />
                    </StackPanel>
                </Border>

                <!-- ProfileSwitch: Target Profile -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16"
                        IsVisible="{Binding IsProfileSwitchAction}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Target Profile" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="Select which profile to switch to"
                                   FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding AvailableProfileIds}"
                                  SelectedItem="{Binding TargetProfileId}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>

                <!-- Folder: Folder ID -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16"
                        IsVisible="{Binding IsFolderAction}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Folder ID" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="Select which folder to open (0-15)"
                                   FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding AvailableFolderIds}"
                                  SelectedItem="{Binding FolderId}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>

                <!-- CustomHID: placeholder -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16"
                        IsVisible="{Binding IsCustomHidAction}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Custom HID" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="Custom HID report configuration (coming soon)"
                                   FontSize="12" Opacity="0.7" />
                    </StackPanel>
                </Border>

                <!-- Shell Command -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16"
                        IsVisible="{Binding IsShellAction}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Shell Command" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="Execute a shell command on the PC when button is pressed"
                                   FontSize="12" Opacity="0.7" />
                        
                        <!-- Command -->
                        <TextBlock Text="Command:" FontSize="12" Margin="0,8,0,0" />
                        <TextBox Text="{Binding ShellCommand}"
                                 PlaceholderText="e.g., git push, npm run build, ./script.sh"
                                 FontFamily="Consolas, Courier New, monospace" />
                        
                        <!-- Working Directory -->
                        <TextBlock Text="Working Directory (optional):" FontSize="12" Margin="0,8,0,0" />
                        <TextBox Text="{Binding ShellWorkingDirectory}"
                                 PlaceholderText="e.g., /home/user/project or C:\Projects\MyApp" />
                        
                        <!-- Wait for Exit -->
                        <CheckBox IsChecked="{Binding ShellWaitForExit}"
                                  Content="Wait for command to complete before continuing"
                                  Margin="0,8,0,0" />
                        
                        <TextBlock Text="⚠️ Shell commands run on the PC, not on the device"
                                   FontSize="11" Opacity="0.6" Foreground="#FFA500" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Sequence Editor -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16"
                        IsVisible="{Binding IsSequenceAction}">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Action Sequence" FontSize="16" FontWeight="Bold" />
                                <TextBlock Text="Execute multiple actions in sequence when button is pressed"
                                           FontSize="12" Opacity="0.7" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SequenceSteps.Count, StringFormat='{}{0}/16 steps'}"
                                       VerticalAlignment="Center"
                                       Opacity="0.7" />
                        </Grid>
                        
                        <!-- Steps List -->
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="8" MinHeight="150">
                            <ScrollViewer MaxHeight="400">
                                <ItemsControl ItemsSource="{Binding SequenceSteps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2D2D30" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                                <StackPanel Spacing="8">
                                                    <!-- Header Row: Step Number, Action Type, Buttons -->
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                                        <!-- Step Number -->
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding StepNumber, StringFormat='#{0}'}"
                                                                   FontWeight="Bold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,12,0"
                                                                   Opacity="0.6" />
                                                        
                                                        <!-- Action Type -->
                                                        <ComboBox Grid.Column="1"
                                                                  ItemsSource="{Binding AvailableActionTypes}"
                                                                  SelectedItem="{Binding ActionType}"
                                                                  HorizontalAlignment="Stretch"
                                                                  Margin="0,0,8,0" />
                                                        
                                                        <!-- Move Up -->
                                                        <Button Grid.Column="2"
                                                                Content="▲"
                                                                Width="28" Height="28"
                                                                Margin="2,0"
                                                                ToolTip.Tip="Move Up"
                                                                Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).MoveStepUpCommand}"
                                                                CommandParameter="{Binding}" />
                                                        
                                                        <!-- Move Down -->
                                                        <Button Grid.Column="3"
                                                                Content="▼"
                                                                Width="28" Height="28"
                                                                Margin="2,0"
                                                                ToolTip.Tip="Move Down"
                                                                Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).MoveStepDownCommand}"
                                                                CommandParameter="{Binding}" />
                                                        
                                                        <!-- Remove -->
                                                        <Button Grid.Column="4"
                                                                Content="✕"
                                                                Width="28" Height="28"
                                                                Margin="2,0,0,0"
                                                                ToolTip.Tip="Remove Step"
                                                                Command="{Binding $parent[ItemsControl].((vm:ButtonConfigDialogViewModel)DataContext).RemoveSequenceStepCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </Grid>
                                                    
                                                    <!-- Action-specific fields -->
                                                    <Border Background="#252526" CornerRadius="4" Padding="8">
                                                        <StackPanel Spacing="6">
                                                            <!-- Keyboard Action -->
                                                            <StackPanel IsVisible="{Binding IsKeyboardStep}" Spacing="4">
                                                                <TextBlock Text="Text to type:" FontSize="11" Opacity="0.7" />
                                                                <TextBox Text="{Binding KeyboardText}"
                                                                         PlaceholderText="e.g., Hello World or Ctrl+C"
                                                                         FontFamily="Consolas, Courier New, monospace" />
                                                            </StackPanel>
                                                            
                                                            <!-- Shell Action -->
                                                            <StackPanel IsVisible="{Binding IsShellStep}" Spacing="4">
                                                                <TextBlock Text="Shell command:" FontSize="11" Opacity="0.7" />
                                                                <TextBox Text="{Binding ShellCommand}"
                                                                         PlaceholderText="e.g., git push, npm run build"
                                                                         FontFamily="Consolas, Courier New, monospace" />
                                                                <TextBlock Text="Working directory (optional):" FontSize="11" Opacity="0.7" Margin="0,4,0,0" />
                                                                <TextBox Text="{Binding WorkingDirectory}"
                                                                         PlaceholderText="/home/user/project" />
                                                                <CheckBox IsChecked="{Binding WaitForExit}"
                                                                          Content="Wait for command to complete"
                                                                          FontSize="11" />
                                                            </StackPanel>
                                                            
                                                            <!-- Delay Action -->
                                                            <StackPanel IsVisible="{Binding IsDelayStep}" Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="Delay duration:" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                                                                <NumericUpDown Value="{Binding DelayMs}"
                                                                               Minimum="0" Maximum="60000"
                                                                               Increment="100"
                                                                               Width="120"
                                                                               FormatString="0" />
                                                                <TextBlock Text="ms" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                            
                                                            <!-- CustomHID Action -->
                                                            <StackPanel IsVisible="{Binding IsCustomHidStep}" Spacing="4">
                                                                <TextBlock Text="HID data (hex):" FontSize="11" Opacity="0.7" />
                                                                <TextBox Text="{Binding CustomHidData}"
                                                                         PlaceholderText="e.g., 01 02 03 04"
                                                                         FontFamily="Consolas, Courier New, monospace" />
                                                            </StackPanel>
                                                            
                                                            <!-- ProfileSwitch Action -->
                                                            <StackPanel IsVisible="{Binding IsProfileSwitchStep}" Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="Target profile:" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                                                                <ComboBox ItemsSource="{Binding AvailableProfileIds}"
                                                                          SelectedItem="{Binding TargetProfileId}"
                                                                          Width="100" />
                                                            </StackPanel>
                                                            
                                                            <!-- Folder Action -->
                                                            <StackPanel IsVisible="{Binding IsFolderStep}" Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="Folder:" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                                                                <ComboBox ItemsSource="{Binding AvailableFolderIds}"
                                                                          SelectedItem="{Binding FolderId}"
                                                                          Width="100" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    
                                                    <!-- Delay Before (common for all steps) -->
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="Delay before this step:" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                                                        <NumericUpDown Value="{Binding DelayBeforeMs}"
                                                                       Minimum="0" Maximum="10000"
                                                                       Increment="50"
                                                                       Width="100"
                                                                       FormatString="0"
                                                                       FontSize="11" />
                                                        <TextBlock Text="ms" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        
                        <!-- Add Step Button -->
                        <Button Content="+ Add Step"
                                HorizontalAlignment="Left"
                                Command="{Binding AddSequenceStepCommand}"
                                IsEnabled="{Binding CanAddMoreSteps}" />
                        
                        <TextBlock Text="💡 Tip: Use Delay action type for pauses between actions. Shell commands execute on PC."
                                   FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Image -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Button Image" FontSize="16" FontWeight="Bold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ImagePath}"
                                     PlaceholderText="Path to image file (160x160 JPEG)"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseImageCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- LED Color -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="LED Color (Hex)" FontSize="16" FontWeight="Bold" />
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <!-- Color Preview -->
                            <Border Grid.Column="0"
                                    Width="32" Height="32"
                                    CornerRadius="4"
                                    BorderBrush="#555"
                                    BorderThickness="1"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding LedColorPreview}" />
                                </Border.Background>
                            </Border>
                            
                            <!-- Hex Input Field -->
                            <TextBox Grid.Column="1"
                                     Text="{Binding LedColorHex}"
                                     PlaceholderText="#FFFFFF"
                                     VerticalAlignment="Center" />
                            
                            <!-- Pick Color Button -->
                            <Button Grid.Column="2"
                                    Content="Pick Color..."
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Command="{Binding ToggleColorPickerCommand}" />
                        </Grid>
                        
                        <!-- RGB Sliders (shown when picking) -->
                        <Border Background="#1E1E1E"
                                CornerRadius="8"
                                Padding="16"
                                IsVisible="{Binding IsColorPickerVisible}">
                            <StackPanel Spacing="12">
                                <!-- Red -->
                                <Grid ColumnDefinitions="50,*,50">
                                    <TextBlock Grid.Column="0" Text="R:" VerticalAlignment="Center" Foreground="#FF6666" />
                                    <Slider Grid.Column="1"
                                            Minimum="0" Maximum="255"
                                            Value="{Binding ColorR}"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding ColorR}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                
                                <!-- Green -->
                                <Grid ColumnDefinitions="50,*,50">
                                    <TextBlock Grid.Column="0" Text="G:" VerticalAlignment="Center" Foreground="#66FF66" />
                                    <Slider Grid.Column="1"
                                            Minimum="0" Maximum="255"
                                            Value="{Binding ColorG}"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding ColorG}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                
                                <!-- Blue -->
                                <Grid ColumnDefinitions="50,*,50">
                                    <TextBlock Grid.Column="0" Text="B:" VerticalAlignment="Center" Foreground="#6666FF" />
                                    <Slider Grid.Column="1"
                                            Minimum="0" Maximum="255"
                                            Value="{Binding ColorB}"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding ColorB}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                
                                <!-- Brightness -->
                                <Separator Margin="0,8" />
                                <Grid ColumnDefinitions="50,*,50">
                                    <TextBlock Grid.Column="0" Text="💡" VerticalAlignment="Center" FontSize="16" />
                                    <Slider Grid.Column="1"
                                            Minimum="0" Maximum="255"
                                            Value="{Binding Brightness}"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Brightness}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <TextBlock Text="Brightness (0-255)" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" />
                                
                                <Button Content="Done"
                                        HorizontalAlignment="Center"
                                        Width="100"
                                        Command="{Binding ToggleColorPickerCommand}" />
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="Enter hex value (e.g., #FF0000) or click 'Pick Color...' to select"
                                   FontSize="11"
                                   Opacity="0.6"
                                   IsVisible="{Binding !IsColorPickerVisible}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="8"
                    Margin="0,20,0,0">
            <Button Content="Cancel" 
                    Width="100"
                    Click="OnCancelClick" />
            <Button Content="Save" 
                    Width="100"
                    Click="OnSaveClick"
                    Classes="accent" />
        </StackPanel>
    </Grid>
</Window>
