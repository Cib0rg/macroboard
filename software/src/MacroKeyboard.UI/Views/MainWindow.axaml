<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MacroKeyboard.UI.ViewModels"
        xmlns:views="using:MacroKeyboard.UI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="MacroKeyboard.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MacroKeyboard Configuration"
        Width="1200" Height="700"
        MinWidth="800" MinHeight="600"
        Classes="Tron">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:ProfileEditorViewModel">
            <views:ProfileEditorView />
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#0D1117" Padding="16,12"
                BorderBrush="#00FFFF" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <Button Content="⌂ Dashboard" Command="{Binding NavigateToDashboardCommand}" />
                    <Button Content="✎ Profile Editor" Command="{Binding NavigateToProfileEditorCommand}" />
                    <Button Content="⚙ Settings" Command="{Binding NavigateToSettingsCommand}" />
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                    <Ellipse Width="12" Height="12"
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#0D1117" Padding="8,4"
                BorderBrush="#00FFFF" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="MacroKeyboard Configuration v1.0"
                           Foreground="#00FFFF"
                           FontSize="12"
                           Opacity="0.8" />
                <TextBlock Grid.Column="1"
                           Text="TRON INTERFACE ACTIVE"
                           Foreground="#00FFFF"
                           FontSize="10"
                           Opacity="0.5" />
            </Grid>
        </Border>
    </Grid>
</Window>
