<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MacroKeyboard.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="MacroKeyboard.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="20" MaxWidth="600">
            <TextBlock Text="⚙ SETTINGS" FontSize="24" FontWeight="Bold" Foreground="#00FFFF" />
            
            <!-- General Settings -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20"
                    BorderBrush="#00FFFF" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="GENERAL" FontSize="18" FontWeight="Bold" Foreground="#00FFFF" />
                    <Separator />
                    
                    <CheckBox Content="Start with Windows"
                              IsChecked="{Binding AutoStart}" />
                    
                    <CheckBox Content="Minimize to tray on close"
                              IsChecked="{Binding MinimizeToTray}" />
                    
                    <CheckBox Content="Show notifications"
                              IsChecked="{Binding ShowNotifications}" />
                </StackPanel>
            </Border>

            <!-- Backend Settings -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20"
                    BorderBrush="#00FFFF" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="BACKEND" FontSize="18" FontWeight="Bold" Foreground="#00FFFF" />
                    <Separator />
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="IPC PORT:" Opacity="0.7" />
                        <NumericUpDown Value="{Binding IpcPort}"
                                       Minimum="1024"
                                       Maximum="65535" />
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="WEBSOCKET PORT:" Opacity="0.7" />
                        <NumericUpDown Value="{Binding WebSocketPort}"
                                       Minimum="1024"
                                       Maximum="65535" />
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="PLUGINS DIRECTORY:" Opacity="0.7" />
                        <TextBox Text="{Binding PluginsDirectory}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- LED Settings -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20"
                    BorderBrush="#00FFFF" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="LED DEFAULTS" FontSize="18" FontWeight="Bold" Foreground="#00FFFF" />
                    <Separator />
                    
                    <TextBlock Text="Default LED color for new buttons:" Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="36" Height="36" CornerRadius="4"
                                BorderBrush="#555" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding DefaultLedColor}" />
                            </Border.Background>
                        </Border>
                        <TextBox Text="{Binding DefaultLedColorHex}"
                                 PlaceholderText="#00FFFF" Width="100"
                                 VerticalAlignment="Center" />
                        <Button Content="🎨" Width="36"
                                Command="{Binding ToggleDefaultColorPickerCommand}"
                                VerticalAlignment="Center" />
                    </StackPanel>
                    
                    <Border Background="#0C0C18" CornerRadius="4" Padding="10"
                            IsVisible="{Binding IsDefaultColorPickerVisible}">
                        <StackPanel Spacing="8">
                            <ColorPicker Color="{Binding DefaultLedColor}"
                                         Width="200" Height="40"
                                         IsAlphaEnabled="False" />
                            <Button Content="Done" HorizontalAlignment="Center" Width="80"
                                    Command="{Binding ToggleDefaultColorPickerCommand}" />
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Default brightness (%):" Opacity="0.7" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Minimum="0" Maximum="100"
                                    Value="{Binding DefaultLedBrightness}"
                                    Width="200" />
                            <TextBlock Text="{Binding DefaultLedBrightness}"
                                       VerticalAlignment="Center" Width="30" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Display Settings -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20"
                    BorderBrush="#00FFFF" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="DISPLAY" FontSize="18" FontWeight="Bold" Foreground="#00FFFF" />
                    <Separator />
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Display backlight brightness (%):" Opacity="0.7" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Minimum="0" Maximum="100"
                                    Value="{Binding DefaultDisplayBrightness}"
                                    Width="200" />
                            <TextBlock Text="{Binding DefaultDisplayBrightness}"
                                       VerticalAlignment="Center" Width="30" />
                        </StackPanel>
                        <TextBlock Text="Controls the PWM backlight level for all button displays (0 = off, 100 = max)"
                                   FontSize="10" Opacity="0.5" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="↺ RESET DEFAULTS"
                        Command="{Binding ResetSettingsCommand}" />
                <Button Content="💾 SAVE SETTINGS"
                        Command="{Binding SaveSettingsCommand}"
                        Background="#0D4429"
                        BorderBrush="#00FF00" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
