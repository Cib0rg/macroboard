<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MacroKeyboard.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="MacroKeyboard.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="20">
            <!-- Device Status Card -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20"
                    BorderBrush="#00FFFF" BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="⚡ DEVICE STATUS"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#00FFFF" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="🔄 REFRESH"
                                    Command="{Binding RequestDeviceInfoCommand}"
                                    Padding="8,4" />
                            <Button Content="📡 PING"
                                    Command="{Binding PingBackendCommand}"
                                    Padding="8,4" />
                        </StackPanel>
                    </Grid>
                    
                    <Separator />
                    
                    <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="8">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="STATUS:" Opacity="0.7" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="12" Height="12"
                                     Fill="{Binding IsDeviceConnected, Converter={StaticResource BoolToColorConverter}}" />
                            <TextBlock Text="{Binding ConnectionStatus}" FontWeight="Bold" Foreground="#FFA500" />
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="DEVICE:" Opacity="0.7" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding DeviceName}"
                                   FontWeight="Bold" />
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="FIRMWARE:" Opacity="0.7" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding FirmwareVersion}" />
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="PROFILE:" Opacity="0.7" />
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding CurrentProfile}" />
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="FOLDER:" Opacity="0.7" />
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding FolderState}" />
                            <TextBlock Text="📁" IsVisible="{Binding IsInFolder}" />
                        </StackPanel>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="BUTTONS:" Opacity="0.7" />
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Text="{Binding ButtonCount}" />
                        
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="PROFILES:" Opacity="0.7" />
                        <TextBlock Grid.Row="6" Grid.Column="1"
                                   Text="{Binding ProfileCount}" />
                        
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="FREE SPACE:" Opacity="0.7" />
                        <TextBlock Grid.Row="7" Grid.Column="1"
                                   Text="{Binding FreeSpace}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Recent Events Card -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20"
                    BorderBrush="#00FFFF" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="📋 EVENT LOG"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#00FFFF" />
                    
                    <Separator />
                    
                    <ListBox ItemsSource="{Binding RecentEvents}"
                             Height="350">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontSize="12" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
