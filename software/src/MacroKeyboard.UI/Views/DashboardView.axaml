<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MacroKeyboard.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="MacroKeyboard.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="20">
            <!-- Device Status Card -->
            <Border Background="#2D2D30" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Device Status" 
                               FontSize="20" 
                               FontWeight="Bold" />
                    
                    <Separator />
                    
                    <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto" 
                          RowSpacing="8">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Device:" />
                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                   Text="{Binding DeviceName}" 
                                   FontWeight="Bold" />
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Firmware:" />
                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                   Text="{Binding FirmwareVersion}" />
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Profile:" />
                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                   Text="{Binding CurrentProfile}" />
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Status:" />
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="12" Height="12"
                                     Fill="{Binding IsDeviceConnected, Converter={StaticResource BoolToColorConverter}}" />
                            <TextBlock Text="{Binding IsDeviceConnected}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Recent Events Card -->
            <Border Background="#2D2D30" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Recent Events" 
                               FontSize="20" 
                               FontWeight="Bold" />
                    
                    <Separator />
                    
                    <ListBox ItemsSource="{Binding RecentEvents}"
                             Height="300"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                           FontFamily="Consolas" 
                                           FontSize="12" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
